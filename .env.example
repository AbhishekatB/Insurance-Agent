# ============================================
# Next.js Application Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# Database Configuration
# Get this from your Neon dashboard
DATABASE_URL=postgresql://[user]:[password]@[host]/[database]?sslmode=require

# Azure Storage Configuration
# Get these from your Azure Storage account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=[account];AccountKey=[key];EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=insurance-claims

# Python Agent Webhook URL
# URL where the Python FastAPI agent is running
AGENT_WEBHOOK_URL=http://127.0.0.1:8080/process-claim

# ============================================
# Python Agent Environment Variables
# These are needed when running temp.py
# ============================================

# Azure OpenAI Configuration
# Get these from your Azure OpenAI resource
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Alternative environment variable names (if using different naming)
# AZURE_OPENAI_KEY=your_azure_openai_api_key_here
